# ============================================================
#  AlumniNetwork-Microservices — Environment Variable Template
# ============================================================
#  Copy this file into EACH service directory as ".env" and
#  fill in the values. See README.md for full details.
#
#  IMPORTANT: The JWT_SECRET must be identical across
#  api-gateway, auth-service, and chat-service.
# ============================================================

# ---- api-gateway/.env ----
# PORT=5000
# JWT_SECRET=<your_shared_secret>
# CLIENT_URL=http://localhost:3000
# AUTH_SERVICE_URL=http://localhost:5001
# USER_SERVICE_URL=http://localhost:5002
# CONNECTION_SERVICE_URL=http://localhost:5003
# CHAT_SERVICE_URL=http://localhost:5004
# EVENT_SERVICE_URL=http://localhost:5005

# ---- auth-service/.env ----
# PORT=5001
# DB_URL=mongodb://127.0.0.1:27017/alumniDB
# JWT_SECRET=<your_shared_secret>

# ---- user-service/.env ----
# PORT=5002
# DB_URL=mongodb://127.0.0.1:27017/alumniDB
# REDIS_URL=redis://localhost:6379

# ---- connection-service/.env ----
# PORT=5003
# DB_URL=mongodb://127.0.0.1:27017/alumniConnDB
# RABBITMQ_URL=amqp://localhost

# ---- chat-service/.env ----
# PORT=5004
# DB_URL=mongodb://127.0.0.1:27017/alumniChatDB
# REDIS_URL=redis://localhost:6379
# RABBITMQ_URL=amqp://localhost
# CLIENT_URL=http://localhost:3000
# JWT_SECRET=<your_shared_secret>

# ---- event-service/.env ----
# PORT=5005
# DB_URL=mongodb://127.0.0.1:27017/alumniEventDB
# RABBITMQ_URL=amqp://localhost

# ---- notification-service/.env ----
# PORT=5006
# RABBITMQ_URL=amqp://localhost
# CLIENT_URL=http://localhost:3000

# ---- frontend/.env ----
# VITE_API_URL=http://localhost:5000/api
